#!/usr/bin/env bash
BACKUP_PATH="${DOTFILES_PATH}/backup"

success "\t$DOTFILES_PATH" "dotfiles"
success "\t$CONFIG_PATH" "config"
success "\t$BACKUP_PATH" "backup"

backup_module() {
    local md="$1"
    local origal_path="${CONFIG_PATH}/${md}"

    if [[ -d "${origal_path}" ]] && [[ ! -L "${origal_path}" ]]; then
        cp -ra "$origal_path/" "${BACKUP_PATH}/${md}"
        rm -rf "${origal_path:?}/" 
        warn "${md}" "backup"
    fi
}

link_module() {
    local md="$1"
    local sou="${DOTFILES_PATH}/config/${md}"
    local dest="${CONFIG_PATH}/${md}"

    if [[ -L "$dest" ]]; then return 0; fi

    ln -sfn "$sou" "$dest" 
    info "dotfiles/$md ---> config/$md" "link"
}

mkdir -p "${BACKUP_PATH}"
for path in "${DOTFILES_PATH}"/config/*; do
    md="${path##*/}"
    backup_module "$md"
    link_module "$md"
done

if [[ -d "${BACKUP_PATH}" ]] && [[ -z "$(ls -A "${BACKUP_PATH}")" ]]; then
    rm -r "${BACKUP_PATH}"
fi

