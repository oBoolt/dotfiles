#!/usr/bin/env bash
THEME_PATH="${DOTFILES_PATH}/themes"
declare -a THEMES

for theme in "${THEME_PATH}"/*; do
    if [[ -d "${theme}" && ! -h "${theme}" ]]; then
        THEMES+=("${theme##*/}")
    fi
done

get() {
    CURRENT_THEME="$(realpath "${THEME_PATH}"/current)"
    if [[ "${CURRENT_THEME##*/}" = "current" ]]; then
        warn "no theme set"
        exit 0
    fi
    info "the current theme is ${CURRENT_THEME##*/}"
}

set() {
    local valid=false
    for theme in "${THEMES[@]}"; do
        if [[ "${theme}" = "${1}" ]]; then
            valid=true
        fi
    done

    if ! ${valid}; then
        error "invalid theme '$1'"
        exit 1
    fi

    ln -sfn "${THEME_PATH}"/"${1}" "${THEME_PATH}"/current
    success "current theme set to ${1}"
    exit 0
}

list() {
    success "${THEMES[*]}"
    exit 0
}

case "${1,,}" in
    get)
        get
        ;;
    set)
        set "$2"
        ;;
    list)
        list
        ;;
    *)
        warn "dotfiles theme <COMMAND>" "help"
        warn "" "help"
        warn "COMMANDS:" "help"
        warn "  get\t\tReturn the current theme" "help"
        warn "  set\t\tSet the current theme to THEME" "help"
        warn "  list\t\tShow all the themes" "help"
        ;;
esac
